# ─────────────────────────────────────────────────────────────────────────────
# AI Construction Intelligence Platform — Variáveis de Ambiente
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copie este arquivo para .env.local
# 2. Preencha ANTHROPIC_API_KEY (obrigatório para IA)
# 3. Supabase e Lumin são opcionais (plataforma funciona sem eles)
# ─────────────────────────────────────────────────────────────────────────────

# ── IA (obrigatório) ──────────────────────────────────────────────────────────
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Autenticação (opcional) ───────────────────────────────────────────────────
# Sem Supabase a plataforma roda em modo demo (sem login)
# Crie um projeto em: https://supabase.com/
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ── Assinatura Digital Lumin (opcional) ───────────────────────────────────────
# Sem Lumin a assinatura funciona em modo simulado
# Obtenha em: https://www.luminpdf.com/
LUMIN_API_KEY=
LUMIN_API_URL=https://api.lumin.com

# ── Webhooks (opcional) ───────────────────────────────────────────────────────
SALES_WEBHOOK_URL=
CLOUD_CORE_SYNC_URL=
