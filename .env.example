# Anthropic API — obrigatório para os agentes IA funcionarem
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — necessário para autenticação e banco de dados
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# (alternativa legada, também aceita)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Sales & Investment Captation Engine — opcional
# URL do webhook para onde o pipeline de vendas envia o payload de campanha
SALES_WEBHOOK_URL=https://seu-servidor.com/webhooks/sales-pipeline

# Edge Computing Layer — opcional
# URL do Cloud Core para receber payloads síncronos dos nós de borda do canteiro
CLOUD_CORE_SYNC_URL=https://seu-servidor.com/webhooks/cloud-core-sync
