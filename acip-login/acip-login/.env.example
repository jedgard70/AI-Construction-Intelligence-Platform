# ─── Supabase ─────────────────────────────────────────────────────────────────
# Copie este arquivo para .env e preencha com as suas credenciais.
# Nunca commite o arquivo .env no Git.

VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# ─── Opcional: habilita logs detalhados em dev ────────────────────────────────
VITE_DEBUG=true
